{
  "name": "bizmatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/db-init.mjs",
    "dev": "next dev",
    "build": "prisma generate && node scripts/db-init.mjs && next build",
    "start": "next start",
    "preview": "npm run build && npm run start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.10.0",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.42.2",
    "jose": "^6.0.11",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "prisma": "^6.10.0",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
