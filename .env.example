# PostgreSQL connection string (Neon, Supabase, Vercel Postgres, or any Postgres).
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/bizmatch?sslmode=require"

# REQUIRED: 32+ char random string. Generate: openssl rand -base64 48
AUTH_SECRET="change-me-in-production"

# Salt for hashing government IDs (verification framework). 16+ chars. Set once.
ID_HASH_SALT="change-me-too-in-production"

# Public URL of the deployment — used in email links.
APP_URL="http://localhost:3000"

# Future verification framework. Off by default: signups are auto-approved.
VERIFICATION_ENABLED="false"

# Optional SMTP relay for outbound email; when unset, emails are logged.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="BizMatch <no-reply@example.com>"

# debug | info | warn | error
LOG_LEVEL="info"
